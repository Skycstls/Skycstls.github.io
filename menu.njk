{% extends "base.njk" %}
{% block content %}
<img src="imgs/logo.png" alt="Logo" style="width: 100px; height: auto;">
  <h1>Menu</h1>
  <ul>
    {% for categoria in menu %}
        <li>
            <h2>{{ categoria.nombre }}</h2>
            <ul>
            {% for plato in categoria.platos %}
                <li>
                {{ plato.nombre }} - ${{ plato.precio }}
                </li>
            {% endfor %}
            </ul>
        </li>
    {% endfor %}
  </ul>
{% endblock %}